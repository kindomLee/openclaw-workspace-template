# OpenClaw workspace — crontab example
#
# This is the OpenClaw-mode cron schedule. Claude Code users should use
# `cron/install-mac.sh` or `cron/install-linux.sh` instead — that
# pipeline runs `claude -p` with per-job prompts and per-job tool
# allowlists, which is a strictly better fit for Claude Code workspaces.
#
# Install (OpenClaw mode):
#     bash scripts/install-cron.sh           # prints these lines for crontab -e
#     bash scripts/install-cron.sh --install # appends to current crontab (asks first)
#
# Environment (canonical names; `scripts/lib/notify.sh` also accepts the
# legacy TELEGRAM_BOT_TOKEN / NOTIFY_TARGET pair for backwards compat):
#   OPENCLAW_WORKSPACE      absolute path to your workspace root (required)
#   TG_BOT_TOKEN            Telegram bot token
#   TG_CHAT_ID              Telegram chat id
#   NOTIFY_CHANNEL          explicit override: telegram | slack | stdout | none
#   SLACK_WEBHOOK_URL       Slack webhook (alternative to Telegram)
#   BROKEN_LINKS_THRESHOLD  default 5
#   NOTES_TODO_THRESHOLD    default 20

OPENCLAW_WORKSPACE=/path/to/your/workspace
# TG_BOT_TOKEN=
# TG_CHAT_ID=
# NOTIFY_CHANNEL=stdout
# SLACK_WEBHOOK_URL=
# BROKEN_LINKS_THRESHOLD=5
# NOTES_TODO_THRESHOLD=20

# --- flag checks (cron → flag → SessionStart hook) ---
30 11 * * 1  $OPENCLAW_WORKSPACE/scripts/cron-broken-links-check.sh  >> $OPENCLAW_WORKSPACE/.claude/cron.log 2>&1
32 11 * * 1  $OPENCLAW_WORKSPACE/scripts/cron-notes-todo-check.sh    >> $OPENCLAW_WORKSPACE/.claude/cron.log 2>&1

# --- memory maintenance (OpenClaw-mode shell wrappers) ---
0  */1 * * * $OPENCLAW_WORKSPACE/scripts/cron-memory-sync.sh         >> $OPENCLAW_WORKSPACE/.claude/cron.log 2>&1
15 3  * * * $OPENCLAW_WORKSPACE/scripts/memory-reflect.sh            >> $OPENCLAW_WORKSPACE/.claude/cron.log 2>&1
30 3  * * 0 $OPENCLAW_WORKSPACE/scripts/memory-dream.sh              >> $OPENCLAW_WORKSPACE/.claude/cron.log 2>&1
45 3  1 * * $OPENCLAW_WORKSPACE/scripts/memory-expire.sh             >> $OPENCLAW_WORKSPACE/.claude/cron.log 2>&1

# --- memory archive (Mac/Linux portable Python janitor; pure shell, no LLM) ---
# rotate-journal: move memory/YYYY-MM-DD*.md older than 5 days to archive-YYYY-MM/
#   (honors ~/.claude/state/mem-access.jsonl access counts to pin hot files)
# archive-timeline: on day 1 of month, move MEMORY.md ### YYYY-MM blocks
#   older than current month into memory/timeline-archive.md
5  9 * * *  $OPENCLAW_WORKSPACE/scripts/cron-memory-archive.sh rotate    >> $OPENCLAW_WORKSPACE/.claude/cron.log 2>&1
10 9 1 * *  $OPENCLAW_WORKSPACE/scripts/cron-memory-archive.sh timeline  >> $OPENCLAW_WORKSPACE/.claude/cron.log 2>&1
