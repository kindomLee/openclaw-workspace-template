<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>org.oracle.memory-archive-rotate</string>
    <!--
      Daily journal rotation. Moves stale memory/YYYY-MM-DD*.md (older
      than rotate-days, default 5) into memory/archive-YYYY-MM/.
      Honors ~/.claude/state/mem-access.jsonl access counts to pin hot
      memories. Pure shell job — does NOT route through cron/runner.sh.
    -->
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-lc</string>
        <string>cd __PROJECT_DIR__ &amp;&amp; bash scripts/cron-memory-archive.sh rotate &gt;&gt; __PROJECT_DIR__/cron/logs/memory-archive-launchd.log 2&gt;&amp;1</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>9</integer>
        <key>Minute</key>
        <integer>5</integer>
    </dict>
    <key>RunAtLoad</key>
    <false/>
    <key>StandardOutPath</key>
    <string>__PROJECT_DIR__/cron/logs/memory-archive-launchd.log</string>
    <key>StandardErrorPath</key>
    <string>__PROJECT_DIR__/cron/logs/memory-archive-launchd.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>__HOME__/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>HOME</key>
        <string>__HOME__</string>
    </dict>
</dict>
</plist>
