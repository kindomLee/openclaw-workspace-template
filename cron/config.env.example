# Oracle Cron — Environment Variables
# Copy to config.env and fill in your values:
#   cp cron/config.env.example cron/config.env
#
# runner.sh sources config.env when present. Missing vars are fine —
# jobs will run but won't send Telegram reports and will use defaults.

# ---- Telegram notifications (recommended) ----
TG_BOT_TOKEN=your-bot-token
TG_CHAT_ID=your-chat-id

# ---- Per-job timeout (prevents claude -p hanging for hours) ----
# Default: 1800 seconds (30 min). Uncomment and bump for jobs that
# genuinely need longer, e.g. memory-reflect over a huge journal.
# JOB_TIMEOUT=1800

# ---- Optional lightweight-LLM backend (skill-evolve / skill-genesis) ----
# Any Anthropic-compatible /v1/messages endpoint.
# LLM_API_URL=https://api.minimax.io/anthropic/v1/messages
# LLM_MODEL=MiniMax-M3
# LLM_API_KEY=
# Legacy alias (still honored as fallback for LLM_API_KEY):
# MINIMAX_API_KEY=

# ---- Workspace override (normally auto-detected by runner.sh) ----
# PROJECT_DIR=/path/to/workspace
