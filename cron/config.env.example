# Oracle Cron — Environment Variables
# Copy to config.env and fill in your values:
#   cp cron/config.env.example cron/config.env

# Telegram notifications (required for most jobs)
TG_BOT_TOKEN=your-bot-token
TG_CHAT_ID=your-chat-id

# MiniMax LLM API (optional, some jobs may use)
MINIMAX_API_KEY=

# Project directory (auto-detected by runner.sh, override if needed)
# PROJECT_DIR=/path/to/workspace
